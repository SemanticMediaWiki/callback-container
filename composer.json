{
	"name": "mediawiki/callback-container",
	"type": "library",
	"description": "A very simple callback container/builder library",
	"keywords": [
		"container"
	],
	"homepage": "https://github.com/SemanticMediaWiki/callback-container",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "James Hong Kong",
			"homepage": "https://github.com/mwjames"
		}
	],
	"require": {
		"php": ">=8.1",
		"psr/log": "~1.0"
	},
	"extra": {
		"branch-alias": {
			"dev-master": "3.x-dev"
		}
	},
	"autoload": {
		"psr-4": {
			"Onoi\\CallbackContainer\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Onoi\\CallbackContainer\\Tests\\": "tests/phpunit/Unit"
		}
	},
	"config": {
		"process-timeout": 0
	},
	"scripts":{
		"phpunit": "phpunit -c phpunit.xml.dist"
	},
	"require-dev": {
		"phpunit/phpunit": "9.6.34"
	},
	"replace": {
		"onoi/callback-container": "*"
	}
}
